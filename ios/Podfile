# Standard Flutter Podfile with robust loading for CI
podhelper_path = File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')
unless File.exist?(podhelper_path)
  # Fallback: Locate podhelper in the Flutter SDK directly (essential for CI)
  if ENV['FLUTTER_ROOT']
    podhelper_path = File.join(ENV['FLUTTER_ROOT'], 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
  end
end

if File.exist?(podhelper_path)
  load podhelper_path
else
  # Ultimate fallback for standard GitHub runner paths (multiple versions)
  fallback_paths = [
    '/Users/runner/hostedtoolcache/flutter/stable-3.24.5-x64/packages/flutter_tools/bin/podhelper.rb',
    '/Users/runner/hostedtoolcache/flutter/stable-3.24.0-x64/packages/flutter_tools/bin/podhelper.rb',
    '/Users/runner/hostedtoolcache/flutter/stable-3.22.0-x64/packages/flutter_tools/bin/podhelper.rb'
  ]
  
  fallback_paths.each do |path|
    if File.exist?(path)
      load path
      break
    end
  end
end

platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      # Additional stabilization flags
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'NO'
      # Fix for CocoaPods 1.15+ compatibility
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_LOCATION=1',
      ]
    end
  end
end
