# Standard Flutter Podfile with robust loading for CI
podhelper_path = File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')
unless File.exist?(podhelper_path)
  # Fallback: Locate podhelper in the Flutter SDK directly (essential for CI)
  if ENV['FLUTTER_ROOT']
    podhelper_path = File.join(ENV['FLUTTER_ROOT'], 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
  end
end

if File.exist?(podhelper_path)
  load podhelper_path
else
  # Ultimate fallback for standard GitHub runner paths
  load '/Users/runner/hostedtoolcache/flutter/stable-3.24.0-x64/packages/flutter_tools/bin/podhelper.rb' rescue nil
end

platform :ios, '13.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      # Additional stabilization flags
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'NO'
    end
  end
end
