platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronous to update.
# This slows down local development and CI, so it's disabled by default.
install! 'cocoapods', :deterministic_uuids => false

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      # Disable code signing for pods
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['INFOPLIST_KEY_LSApplicationCategoryType'] = 'public.app-category.utilities'
    end
  end
end
